---
import Header from "@/components/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { getTranslation } from "@/features/i18n/domain/getTranslation";
import type { Language } from "@/features/i18n/config/languages";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang: Language; // REQUIRED prop for [lang] routing
}

const {
  lang,
  title: customTitle,
  description: customDescription,
} = Astro.props;

// Use lang prop as the language
const language = lang;
const t = getTranslation(language);

const title = customTitle || t.metadata.PAGE_TITLE_DEFAULT;
const description = customDescription || t.metadata.PAGE_DESCRIPTION_DEFAULT;
---

<html lang={language}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:inline>
      html:not([data-theme-initialized]) {
        visibility: hidden;
      }
    </style>
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme");
        const systemDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        if (theme === "dark" || (!theme && systemDark)) {
          document.documentElement.classList.add("dark");
        }
        document.documentElement.setAttribute("data-theme-initialized", "true");
      })();
    </script>
  </head>
  <body
    class="grid grid-rows-[1fr_auto] min-h-dvh bg-zinc-50 dark:bg-zinc-900 text-zinc-900 dark:text-white antialiased"
  >
    <Header lang={language} />
    <main class="h-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer lang={language} />
  </body>
  <Analytics />
  <SpeedInsights />
  <script>
    import { initAnalytics } from "@/lib/analytics";
    initAnalytics();
    document.addEventListener("astro:page-load", initAnalytics);
  </script>
</html>
