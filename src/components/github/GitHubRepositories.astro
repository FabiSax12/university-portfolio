---
import {
  Star,
  GitFork,
  ExternalLink,
  Clock,
  Code2,
  Shield,
  Eye,
  EyeOff,
} from "lucide-astro";
import Link from "../ui/Link.astro";

interface Props {
  username: string;
}

const { username } = Astro.props;
---

<div
  class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
  id="repositories-grid"
>
  <!-- Loading State -->
  <div id="repos-loading" class="md:col-span-2 lg:col-span-3 text-center py-12">
    <div
      class="inline-flex items-center gap-2 text-zinc-600 dark:text-zinc-400"
    >
      <div
        class="w-6 h-6 border-2 border-current border-t-transparent rounded-full animate-spin"
      >
      </div>
      <span id="loading-text">Cargando repositorios destacados...</span>
    </div>
  </div>

  <!-- Error State -->
  <div
    id="repos-error"
    class="hidden md:col-span-2 lg:col-span-3 text-center py-12"
  >
    <div class="text-red-500">
      <Code2 class="w-12 h-12 mx-auto mb-4 opacity-50" />
      <p class="text-lg font-medium mb-2">Error al cargar repositorios</p>
      <p class="text-sm opacity-75">Intenta recargar la página</p>
    </div>
  </div>
</div>

<!-- Repository Filter Controls -->
<div
  id="repo-controls"
  class="hidden mt-8 flex flex-wrap items-center justify-between gap-4"
>
  <div class="flex items-center gap-4">
    <span class="text-sm font-medium text-zinc-700 dark:text-zinc-300"
      >Filtros:</span
    >
    <div class="flex items-center gap-2">
      <button
        id="filter-all"
        class="filter-btn active px-3 py-1 text-sm rounded-full bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300"
      >
        Todos
      </button>
      <button
        id="filter-public"
        class="filter-btn px-3 py-1 text-sm rounded-full bg-zinc-100 dark:bg-zinc-700 text-zinc-600 dark:text-zinc-400 hover:bg-zinc-200 dark:hover:bg-zinc-600"
      >
        Públicos
      </button>
      <button
        id="filter-private"
        class="filter-btn px-3 py-1 text-sm rounded-full bg-zinc-100 dark:bg-zinc-700 text-zinc-600 dark:text-zinc-400 hover:bg-zinc-200 dark:hover:bg-zinc-600"
      >
        <Shield class="w-3 h-3 mr-1 inline" />
        Privados
      </button>
    </div>
  </div>

  <div class="flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400">
    <span
      >Mostrando <span id="visible-count">0</span> de <span id="total-count"
        >0</span
      > repositorios</span
    >
  </div>
</div>

<script>
  import {
    githubConfig,
    hasApiToken,
    // getGitHubHeaders,
    callInternalGraphQL,
    GITHUB_QUERIES,
    calculateRepoScore,
    getLanguageColor,
  } from "@/data/github-config";

  interface GitHubRepo {
    id?: number;
    name: string;
    nameWithOwner?: string;
    full_name?: string;
    description: string;
    html_url?: string;
    url?: string;
    homepage?: string;
    homepageUrl?: string;
    language?: string;
    primaryLanguage?: { name: string; color: string };
    stargazers_count?: number;
    stargazerCount?: number;
    forks_count?: number;
    forkCount?: number;
    updated_at?: string;
    updatedAt?: string;
    pushedAt?: string;
    topics?: string[];
    repositoryTopics?: { nodes: Array<{ topic: { name: string } }> };
    fork?: boolean;
    isFork?: boolean;
    archived?: boolean;
    isArchived?: boolean;
    private?: boolean;
    isPrivate?: boolean;
    size?: number;
    diskUsage?: number;
    licenseInfo?: { name: string; spdxId: string };
    watchers?: { totalCount: number };
    issues?: { totalCount: number };
    pullRequests?: { totalCount: number };
    createdAt?: string;
    created_at?: string;
  }

  class EnhancedGitHubRepositories {
    private username: string;
    private cache: Map<string, any> = new Map();
    private readonly CACHE_DURATION = githubConfig.cache.duration;
    private hasToken: boolean;
    private allRepos: GitHubRepo[] = [];
    private currentFilter: string = "all";

    constructor(username: string) {
      this.username = username;
      this.hasToken = true; // hasApiToken();
      this.init();
    }

    async init() {
      try {
        if (this.hasToken) {
          await this.loadEnhancedRepositories();
        } else {
          await this.loadBasicRepositories();
        }
        this.hideLoading();
        this.setupFilters();
        this.showControls();
      } catch (error) {
        console.error("Error loading GitHub repositories:", error);
        // Fallback to basic repos if enhanced fails
        if (this.hasToken) {
          console.log("Falling back to REST API...");
          try {
            await this.loadBasicRepositories();
            this.hideLoading();
            this.setupFilters();
          } catch (fallbackError) {
            this.showError();
          }
        } else {
          this.showError();
        }
      }
    }

    private async fetchWithCache(
      url: string,
      options: RequestInit = {},
    ): Promise<any> {
      const cacheKey = url + JSON.stringify(options);
      const cached = this.cache.get(cacheKey);

      if (cached && Date.now() - cached.timestamp < this.CACHE_DURATION) {
        return cached.data;
      }

      try {
        // const headers = { ...getGitHubHeaders(), ...options.headers };
        const response = await fetch(url, { ...options });

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const { data } = await response.json();
        this.cache.set(cacheKey, { data, timestamp: Date.now() });
        return data;
      } catch (error) {
        if (cached) {
          return cached.data;
        }
        throw error;
      }
    }

    async loadEnhancedRepositories() {
      const loadingText = document.getElementById("loading-text");
      if (loadingText)
        loadingText.textContent =
          "Cargando repositorios con datos avanzados...";

      console.log("Loading enhanced repositories with GraphQL...");

      let allRepos: GitHubRepo[] = [];
      let hasNextPage = true;
      let after: string | null = null;

      // Paginate through all repositories
      while (hasNextPage && allRepos.length < 200) {
        // Limit to prevent excessive API calls
        const { data } = await callInternalGraphQL(
          GITHUB_QUERIES.REPOSITORIES,
          {
            username: this.username,
            first: 50,
            after,
          },
        );

        const repoData = data.user.repositories;
        allRepos.push(...repoData.nodes);

        hasNextPage = repoData.pageInfo.hasNextPage;
        after = repoData.pageInfo.endCursor;
      }

      this.allRepos = this.processRepositories(allRepos);
      this.renderRepositories(this.allRepos);
    }

    async loadBasicRepositories() {
      const loadingText = document.getElementById("loading-text");
      if (loadingText)
        loadingText.textContent = "Cargando repositorios públicos...";

      console.log("Loading basic repositories with REST API...");

      const repos: GitHubRepo[] = await this.fetchWithCache(
        `/api/github?endpoint=repos`,
      );

      this.allRepos = this.processRepositories(repos);
      this.renderRepositories(this.allRepos);
    }

    private processRepositories(repos: GitHubRepo[]): GitHubRepo[] {
      // Filter out forks and archived repositories unless configured otherwise
      const filteredRepos = repos.filter((repo) => {
        const isFork = repo.fork || repo.isFork;
        const isArchived = repo.archived || repo.isArchived;

        return !isFork && !isArchived;
      });

      // Sort repositories by calculated score
      const sortedRepos = filteredRepos.sort((a, b) => {
        const scoreA = calculateRepoScore(a);
        const scoreB = calculateRepoScore(b);
        return scoreB - scoreA;
      });

      // Return top repositories
      return sortedRepos.slice(0, githubConfig.ui.maxFeaturedRepos);
    }

    private renderRepositories(repos: GitHubRepo[]) {
      const container = document.getElementById("repositories-grid");
      if (!container) return;

      // Clear previous content except loading/error states
      const existingCards = container.querySelectorAll(".repo-card");
      existingCards.forEach((card) => card.remove());

      repos.forEach((repo, index) => {
        const repoCard = this.createRepoCard(repo);
        container.appendChild(repoCard);

        // Animate cards with stagger
        setTimeout(() => {
          repoCard.style.opacity = "1";
          repoCard.style.transform = "translateY(0)";
        }, index * 100);
      });

      this.updateCounters();
    }

    private createRepoCard(repo: GitHubRepo): HTMLElement {
      const card = document.createElement("div");
      card.className =
        "repo-card opacity-0 transform translate-y-4 transition-all duration-500 ease-out";

      // Determine if repo is private
      const isPrivate = repo.private || repo.isPrivate;
      const repoUrl =
        repo.html_url ||
        repo.url ||
        `https://github.com/${repo.nameWithOwner || repo.full_name}`;
      const homepage = repo.homepage || repo.homepageUrl;

      // Get language info
      const language = repo.primaryLanguage?.name || repo.language;
      const languageColor =
        repo.primaryLanguage?.color || getLanguageColor(language || "");

      // Get stats
      const stars = repo.stargazers_count || repo.stargazerCount || 0;
      const forks = repo.forks_count || repo.forkCount || 0;
      const watchers = repo.watchers?.totalCount || 0;
      const issues = repo.issues?.totalCount || 0;

      // Get last updated
      const lastUpdate = repo.updated_at || repo.updatedAt || repo.pushedAt;
      const lastUpdated = lastUpdate
        ? this.getRelativeTime(lastUpdate)
        : "Sin actualizar";

      // Get topics
      const topics =
        repo.repositoryTopics?.nodes?.map((t) => t.topic.name) ||
        repo.topics ||
        [];

      // Set filter attributes
      card.setAttribute("data-visibility", isPrivate ? "private" : "public");

      card.innerHTML = `
        <div class="bg-white dark:bg-zinc-800/50 rounded-2xl p-6 border border-zinc-200 dark:border-zinc-700 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 h-full flex flex-col group ${isPrivate ? "ring-1 ring-violet-200 dark:ring-violet-800" : ""}">
          <!-- Header -->
          <div class="flex items-start justify-between mb-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <h3 class="font-bold text-lg text-zinc-900 dark:text-white truncate group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">
                  ${repo.name}
                </h3>
                ${
                  isPrivate
                    ? `
                  <div class="flex items-center gap-1 px-2 py-1 bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 rounded-full text-xs">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                    </svg>
                    Privado
                  </div>
                `
                    : ""
                }
              </div>

              <div class="flex items-center gap-4 text-sm text-zinc-500 dark:text-zinc-400">
                ${
                  language
                    ? `
                  <div class="flex items-center gap-1">
                    <div class="w-3 h-3 rounded-full" style="background-color: ${languageColor}"></div>
                    <span>${language}</span>
                  </div>
                `
                    : ""
                }
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span>${lastUpdated}</span>
                </div>
              </div>
            </div>

            <a
              href="${repoUrl}"
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 rounded-lg bg-zinc-100 dark:bg-zinc-700 hover:bg-zinc-200 dark:hover:bg-zinc-600 text-zinc-600 dark:text-zinc-400 hover:text-violet-600 dark:hover:text-violet-400 transition-all duration-200 opacity-0 group-hover:opacity-100"
              aria-label="Ver repositorio en GitHub"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </div>

          <!-- Description -->
          <div class="flex-1 mb-4">
            <p class="text-zinc-600 dark:text-zinc-400 text-sm leading-relaxed line-clamp-3">
              ${repo.description || "Sin descripción disponible"}
            </p>
          </div>

          <!-- Topics -->
          ${
            topics.length > 0
              ? `
            <div class="mb-4">
              <div class="flex flex-wrap gap-1">
                ${topics
                  .slice(0, 3)
                  .map(
                    (topic) => `
                  <span class="text-xs px-2 py-1 bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 rounded-full">
                    ${topic}
                  </span>
                `,
                  )
                  .join("")}
                ${
                  topics.length > 3
                    ? `
                  <span class="text-xs px-2 py-1 bg-zinc-100 dark:bg-zinc-700 text-zinc-600 dark:text-zinc-400 rounded-full">
                    +${topics.length - 3}
                  </span>
                `
                    : ""
                }
              </div>
            </div>
          `
              : ""
          }

          <!-- Enhanced Stats -->
          <div class="flex items-center justify-between pt-4 border-t border-zinc-100 dark:border-zinc-700">
            <div class="flex items-center gap-4 text-sm text-zinc-500 dark:text-zinc-400">
              <div class="flex items-center gap-1" title="Estrellas">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                </svg>
                <span>${stars}</span>
              </div>
              <div class="flex items-center gap-1" title="Forks">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.707 3.293a1 1 0 010 1.414L5.414 7H11a7 7 0 017 7v2a1 1 0 11-2 0v-2a5 5 0 00-5-5H5.414l2.293 2.293a1 1 0 11-1.414 1.414L2.586 7l3.707-3.707a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>${forks}</span>
              </div>
              ${
                watchers > 0
                  ? `
                <div class="flex items-center gap-1" title="Watchers">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span>${watchers}</span>
                </div>
              `
                  : ""
              }
              ${
                issues > 0
                  ? `
                <div class="flex items-center gap-1 text-orange-500" title="Issues abiertos">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                  </svg>
                  <span>${issues}</span>
                </div>
              `
                  : ""
              }
            </div>

            <div class="flex items-center gap-2">
              ${
                homepage
                  ? `
                <a
                  href="${homepage}"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs px-3 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-full hover:bg-green-200 dark:hover:bg-green-900/50 transition-colors"
                  title="Ver demo en vivo"
                >
                  <svg class="w-3 h-3 mr-1 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                  Demo
                </a>
              `
                  : ""
              }
            </div>
          </div>
        </div>
      `;

      return card;
    }

    private setupFilters() {
      if (!this.hasToken) return; // No filters needed for public-only repos

      const filterButtons = document.querySelectorAll(".filter-btn");

      filterButtons.forEach((button) => {
        button.addEventListener("click", (e) => {
          const target = e.target as HTMLElement;
          const filter = target.id.replace("filter-", "");

          // Update active button
          filterButtons.forEach((btn) => {
            btn.classList.remove(
              "active",
              "bg-violet-100",
              "dark:bg-violet-900/30",
              "text-violet-700",
              "dark:text-violet-300",
            );
            btn.classList.add(
              "bg-zinc-100",
              "dark:bg-zinc-700",
              "text-zinc-600",
              "dark:text-zinc-400",
            );
          });

          target.classList.add(
            "active",
            "bg-violet-100",
            "dark:bg-violet-900/30",
            "text-violet-700",
            "dark:text-violet-300",
          );
          target.classList.remove(
            "bg-zinc-100",
            "dark:bg-zinc-700",
            "text-zinc-600",
            "dark:text-zinc-400",
          );

          this.currentFilter = filter;
          this.applyFilter();
        });
      });
    }

    private applyFilter() {
      const cards = document.querySelectorAll(".repo-card");

      cards.forEach((card) => {
        const visibility = card.getAttribute("data-visibility");
        const shouldShow =
          this.currentFilter === "all" ||
          (this.currentFilter === "public" && visibility === "public") ||
          (this.currentFilter === "private" && visibility === "private");

        if (shouldShow) {
          card.classList.remove("hidden");
        } else {
          card.classList.add("hidden");
        }
      });

      this.updateCounters();
    }

    private updateCounters() {
      const totalEl = document.getElementById("total-count");
      const visibleEl = document.getElementById("visible-count");

      const totalCards = document.querySelectorAll(".repo-card").length;
      const visibleCards = document.querySelectorAll(
        ".repo-card:not(.hidden)",
      ).length;

      if (totalEl) totalEl.textContent = totalCards.toString();
      if (visibleEl) visibleEl.textContent = visibleCards.toString();
    }

    private getRelativeTime(dateString: string): string {
      const date = new Date(dateString);
      const now = new Date();
      const diffTime = Math.abs(now.getTime() - date.getTime());
      const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));

      if (diffDays === 0) return "Hoy";
      if (diffDays === 1) return "Ayer";
      if (diffDays < 7) return `Hace ${diffDays} días`;
      if (diffDays < 30) return `Hace ${Math.floor(diffDays / 7)} semanas`;
      if (diffDays < 365) return `Hace ${Math.floor(diffDays / 30)} meses`;
      return `Hace ${Math.floor(diffDays / 365)} años`;
    }

    private showControls() {
      if (
        this.hasToken &&
        this.allRepos.some((repo) => repo.private || repo.isPrivate)
      ) {
        const controls = document.getElementById("repo-controls");
        if (controls) {
          controls.classList.remove("hidden");
        }
      }
    }

    private hideLoading() {
      const loadingEl = document.getElementById("repos-loading");
      if (loadingEl) {
        loadingEl.style.display = "none";
      }
    }

    private showError() {
      const loadingEl = document.getElementById("repos-loading");
      const errorEl = document.getElementById("repos-error");

      if (loadingEl) loadingEl.style.display = "none";
      if (errorEl) {
        errorEl.classList.remove("hidden");
      }
    }
  }

  // Initialize with intersection observer for lazy loading
  function initEnhancedGitHubRepositories() {
    const reposSection = document.getElementById("repositories-grid");
    if (!reposSection) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const username =
              document
                .querySelector("[data-username]")
                ?.getAttribute("data-username") || "FabiSax12";
            new EnhancedGitHubRepositories(username);
            observer.disconnect();
          }
        });
      },
      { rootMargin: "100px" },
    );

    observer.observe(reposSection);
  }

  // Initialize on DOM ready
  if (document.readyState === "loading") {
    document.addEventListener(
      "DOMContentLoaded",
      initEnhancedGitHubRepositories,
    );
  } else {
    initEnhancedGitHubRepositories();
  }

  // Re-initialize on page changes (for Astro)
  document.addEventListener("astro:page-load", initEnhancedGitHubRepositories);
</script>

<style>
  /* Line clamp utility for description */
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Smooth hover animations */
  .group:hover a[aria-label="Ver repositorio en GitHub"] {
    transform: translateX(2px) translateY(-2px);
  }

  /* Filter button transitions */
  .filter-btn {
    transition: all 0.2s ease;
  }

  .filter-btn:hover {
    transform: translateY(-1px);
  }

  /* Private repo indicator */
  .repo-card[data-visibility="private"] {
    position: relative;
  }

  .repo-card[data-visibility="private"]::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #8b5cf6, #a855f7);
    border-radius: 1rem 1rem 0 0;
  }
</style>
