---
import {
  GitCommit,
  GitBranch,
  GitPullRequest,
  Calendar,
  Activity,
} from "lucide-astro";

interface Props {
  username: string;
}

const { username } = Astro.props;
---

<div class="grid grid-cols-1 lg:grid-cols-1 gap-8">
  <!-- Contribution Activity -->
  <div
    class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-8 border border-green-200 dark:border-green-700"
  >
    <div class="flex items-center gap-3 mb-6">
      <div class="p-2 bg-green-100 dark:bg-green-800/50 rounded-lg">
        <Activity class="w-5 h-5 text-green-600 dark:text-green-400" />
      </div>
      <h3 class="text-lg font-bold text-zinc-900 dark:text-white">
        Contribuciones Recientes
      </h3>
    </div>

    <!-- Contribution Graph Placeholder -->
    <div id="contribution-chart" class="space-y-4">
      <!-- Loading State -->
      <div id="contribution-loading" class="text-center py-8">
        <div
          class="inline-flex items-center gap-2 text-zinc-600 dark:text-zinc-400"
        >
          <div
            class="w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"
          >
          </div>
          Analizando contribuciones...
        </div>
      </div>

      <!-- Error State -->
      <div id="contribution-error" class="hidden text-center py-8 text-red-500">
        <p class="text-sm">Error al cargar las contribuciones</p>
      </div>
    </div>

    <!-- Contribution Stats -->
    <div
      id="contribution-stats"
      class="hidden grid grid-cols-2 gap-4 mt-6 pt-6 border-t border-green-200 dark:border-green-700"
    >
      <div class="text-center">
        <div
          class="text-2xl font-bold text-green-600 dark:text-green-400"
          id="total-contributions"
        >
          0
        </div>
        <div class="text-sm text-zinc-600 dark:text-zinc-400">Este año</div>
      </div>
      <div class="text-center">
        <div
          class="text-2xl font-bold text-green-600 dark:text-green-400"
          id="current-streak"
        >
          0
        </div>
        <div class="text-sm text-zinc-600 dark:text-zinc-400">
          Días seguidos
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Events -->
  <div
    class="bg-gradient-to-br from-blue-50 to-cyan-50 dark:from-blue-900/20 dark:to-cyan-900/20 rounded-2xl p-8 border border-blue-200 dark:border-blue-700"
  >
    <div class="flex items-center gap-3 mb-6">
      <div class="p-2 bg-blue-100 dark:bg-blue-800/50 rounded-lg">
        <GitCommit class="w-5 h-5 text-blue-600 dark:text-blue-400" />
      </div>
      <h3 class="text-lg font-bold text-zinc-900 dark:text-white">
        Actividad Reciente
      </h3>
    </div>

    <!-- Events List -->
    <div
      id="recent-events"
      class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3"
    >
      <!-- Loading State -->
      <div id="events-loading" class="text-center py-8">
        <div
          class="inline-flex items-center gap-2 text-zinc-600 dark:text-zinc-400"
        >
          <div
            class="w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"
          >
          </div>
          Cargando eventos...
        </div>
      </div>

      <!-- Error State -->
      <div id="events-error" class="hidden text-center py-8 text-red-500">
        <p class="text-sm">Error al cargar la actividad</p>
      </div>
    </div>
  </div>
</div>

<script>
  import { githubConfig } from "@/data/github-config";

  interface GitHubEvent {
    id: string;
    type: string;
    repo: {
      name: string;
      url: string;
    };
    created_at: string;
    payload: any;
  }

  class GitHubActivity {
    private username: string;
    private cache: Map<string, any> = new Map();
    private readonly CACHE_DURATION = 5 * 60 * 1000; // 5 minutes

    constructor(username: string) {
      this.username = username;
      this.init();
    }

    async init() {
      try {
        await Promise.all([this.loadContributions(), this.loadRecentEvents()]);
        this.hideLoading();
      } catch (error) {
        console.error("Error loading GitHub activity:", error);
        this.showError();
      }
    }

    private async fetchWithCache(url: string): Promise<any> {
      const cacheKey = url;
      const cached = this.cache.get(cacheKey);

      if (cached && Date.now() - cached.timestamp < this.CACHE_DURATION) {
        return cached.data;
      }

      try {
        const response = await fetch(url);
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const data = await response.json();
        this.cache.set(cacheKey, { data, timestamp: Date.now() });
        return data;
      } catch (error) {
        if (cached) {
          return cached.data;
        }
        throw error;
      }
    }

    async loadContributions() {
      // Simulate contribution data (GitHub's contribution API requires authentication)
      // In a real implementation, you'd use a backend service or GitHub's GraphQL API
      this.renderContributionChart();
      this.showContributionStats();
    }

    async loadRecentEvents() {
      try {
        const events: GitHubEvent[] = await this.fetchWithCache(
          `/api/github?endpoint=events`,
        );

        this.renderRecentEvents(events.data);
      } catch (error) {
        console.error("Error loading events:", error);
        this.showEventsError();
      }
    }

    private renderContributionChart() {
      const container = document.getElementById("contribution-chart");
      const loading = document.getElementById("contribution-loading");
      if (!container || !loading) return;

      loading.style.display = "none";

      // Generate mock contribution data for the last 12 weeks
      const weeks = 12;
      const days = 7;

      const chartContainer = document.createElement("div");
      chartContainer.className = "space-y-2";

      const headerDiv = document.createElement("div");
      headerDiv.className =
        "flex justify-between text-xs text-zinc-500 dark:text-zinc-400 mb-2";
      headerDiv.innerHTML = `
        <span>Últimas ${weeks} semanas</span>
        <span>Más reciente</span>
      `;
      chartContainer.appendChild(headerDiv);

      const gridContainer = document.createElement("div");
      gridContainer.className = "grid grid-cols-12 gap-1";

      for (let week = weeks - 1; week >= 0; week--) {
        const weekDiv = document.createElement("div");
        weekDiv.className = "space-y-1";

        for (let day = 0; day < days; day++) {
          const contributionLevel = Math.floor(Math.random() * 5); // 0-4 contribution levels
          const dayDiv = document.createElement("div");
          dayDiv.className = `w-3 h-3 rounded-sm ${this.getContributionColor(contributionLevel)}`;
          dayDiv.title = `${contributionLevel} contribuciones`;
          weekDiv.appendChild(dayDiv);
        }

        gridContainer.appendChild(weekDiv);
      }

      chartContainer.appendChild(gridContainer);

      // Legend
      const legendDiv = document.createElement("div");
      legendDiv.className =
        "flex items-center justify-between mt-4 text-xs text-zinc-500 dark:text-zinc-400";
      legendDiv.innerHTML = `
        <span>Menos</span>
        <div class="flex gap-1">
          ${[0, 1, 2, 3, 4]
            .map(
              (level) =>
                `<div class="w-3 h-3 rounded-sm ${this.getContributionColor(level)}"></div>`,
            )
            .join("")}
        </div>
        <span>Más</span>
      `;
      chartContainer.appendChild(legendDiv);

      container.appendChild(chartContainer);
    }

    private getContributionColor(level: number): string {
      const colors = [
        "bg-zinc-100 dark:bg-zinc-800",
        "bg-green-200 dark:bg-green-900/50",
        "bg-green-300 dark:bg-green-800/70",
        "bg-green-400 dark:bg-green-700",
        "bg-green-500 dark:bg-green-600",
      ];
      return colors[level] || colors[0];
    }

    private showContributionStats() {
      const statsContainer = document.getElementById("contribution-stats");
      const totalEl = document.getElementById("total-contributions");
      const streakEl = document.getElementById("current-streak");

      if (statsContainer) {
        statsContainer.classList.remove("hidden");
      }

      // Mock data - in real implementation, calculate from actual contributions
      const totalContributions = Math.floor(Math.random() * 500) + 100;
      const currentStreak = Math.floor(Math.random() * 30) + 1;

      if (totalEl) {
        this.animateNumber(totalEl, totalContributions);
      }
      if (streakEl) {
        this.animateNumber(streakEl, currentStreak);
      }
    }

    private renderRecentEvents(events: GitHubEvent[]) {
      const container = document.getElementById("recent-events");
      const loading = document.getElementById("events-loading");
      if (!container || !loading) return;

      loading.style.display = "none";

      // Filter and limit events
      const relevantEvents = events
        .filter((event) =>
          [
            "PushEvent",
            "CreateEvent",
            "PullRequestEvent",
            "IssuesEvent",
          ].includes(event.type),
        )
        .slice(0, 5);

      if (relevantEvents.length === 0) {
        container.innerHTML = `
          <div class="text-center py-8 text-zinc-500 dark:text-zinc-400">
            <svg class="w-8 h-8 mx-auto mb-2 opacity-50" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 1.414L10.586 9H7a1 1 0 100 2h3.586l-1.293 1.293a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" clip-rule="evenodd"></path>
            </svg>
            <p class="text-sm">No hay actividad reciente visible</p>
          </div>
        `;
        return;
      }

      relevantEvents.forEach((event, index) => {
        const eventElement = this.createEventElement(event);
        container.appendChild(eventElement);

        // Animate with stagger
        setTimeout(() => {
          eventElement.style.opacity = "1";
          eventElement.style.transform = "translateX(0)";
        }, index * 100);
      });
    }

    private createEventElement(event: GitHubEvent): HTMLElement {
      const element = document.createElement("div");
      element.className =
        "opacity-0 transform translate-x-4 transition-all duration-300 ease-out";

      const { icon, action, details } = this.getEventInfo(event);
      const timeAgo = this.getRelativeTime(event.created_at);
      const repoName = event.repo.name.split("/").pop();

      element.innerHTML = `
        <div class="flex items-start gap-3 p-4 bg-white/50 dark:bg-black/20 rounded-lg hover:bg-white/70 dark:hover:bg-black/30 transition-colors">
          <div class="flex-shrink-0 p-2 bg-blue-100 dark:bg-blue-800/50 rounded-lg">
            ${icon}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-zinc-900 dark:text-white font-medium">
              ${action}
            </p>
            <p class="text-xs text-zinc-600 dark:text-zinc-400 mt-1">
              en <span class="font-medium">${repoName}</span>
            </p>
            ${details ? `<p class="text-xs text-zinc-500 dark:text-zinc-500 mt-1">${details}</p>` : ""}
            <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-2">
              ${timeAgo}
            </p>
          </div>
        </div>
      `;

      return element;
    }

    private getEventInfo(event: GitHubEvent): {
      icon: string;
      action: string;
      details?: string;
    } {
      const iconClass = "w-4 h-4 text-blue-600 dark:text-blue-400";

      switch (event.type) {
        case "PushEvent":
          const commits = event.payload.commits?.length || 1;
          return {
            icon: `<svg class="${iconClass}" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 1.414L10.586 9H7a1 1 0 100 2h3.586l-1.293 1.293a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" clip-rule="evenodd"></path></svg>`,
            action: `Pushed ${commits} commit${commits > 1 ? "s" : ""}`,
            details:
              event.payload.commits?.[0]?.message || "Commits realizados",
          };

        case "CreateEvent":
          const refType = event.payload.ref_type;
          return {
            icon: `<svg class="${iconClass}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>`,
            action: `Created ${refType}`,
            details: event.payload.ref
              ? `${refType}: ${event.payload.ref}`
              : undefined,
          };

        case "PullRequestEvent":
          const action = event.payload.action;
          const prNumber = event.payload.pull_request?.number;
          return {
            icon: `<svg class="${iconClass}" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2H6zm1 2a1 1 0 000 2h6a1 1 0 100-2H7zm6 7a1 1 0 011 1v3a1 1 0 11-2 0v-3a1 1 0 011-1zM7 10a1 1 0 000 2h3a1 1 0 100-2H7z" clip-rule="evenodd"></path></svg>`,
            action: `${action.charAt(0).toUpperCase() + action.slice(1)} pull request`,
            details: prNumber ? `#${prNumber}` : undefined,
          };

        case "IssuesEvent":
          const issueAction = event.payload.action;
          const issueNumber = event.payload.issue?.number;
          return {
            icon: `<svg class="${iconClass}" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path></svg>`,
            action: `${issueAction.charAt(0).toUpperCase() + issueAction.slice(1)} issue`,
            details: issueNumber ? `#${issueNumber}` : undefined,
          };

        default:
          return {
            icon: `<svg class="${iconClass}" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 1.414L10.586 9H7a1 1 0 100 2h3.586l-1.293 1.293a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" clip-rule="evenodd"></path></svg>`,
            action: event.type.replace("Event", ""),
            details: undefined,
          };
      }
    }

    private getRelativeTime(dateString: string): string {
      const date = new Date(dateString);
      const now = new Date();
      const diffTime = Math.abs(now.getTime() - date.getTime());
      const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
      const diffHours = Math.floor(diffTime / (1000 * 60 * 60));
      const diffMinutes = Math.floor(diffTime / (1000 * 60));

      if (diffMinutes < 60) return `Hace ${diffMinutes} min`;
      if (diffHours < 24) return `Hace ${diffHours}h`;
      if (diffDays === 1) return "Ayer";
      if (diffDays < 7) return `Hace ${diffDays} días`;
      if (diffDays < 30) return `Hace ${Math.floor(diffDays / 7)} semanas`;
      return `Hace ${Math.floor(diffDays / 30)} meses`;
    }

    private animateNumber(
      element: HTMLElement,
      target: number,
      duration: number = 1000,
    ) {
      const start = 0;
      const startTime = performance.now();

      const animate = (currentTime: number) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);

        // Easing function
        const easeOut = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(start + (target - start) * easeOut);

        element.textContent = current.toString();

        if (progress < 1) {
          requestAnimationFrame(animate);
        }
      };

      requestAnimationFrame(animate);
    }

    private hideLoading() {
      const contributionLoading = document.getElementById(
        "contribution-loading",
      );
      const eventsLoading = document.getElementById("events-loading");

      if (contributionLoading) contributionLoading.style.display = "none";
      if (eventsLoading) eventsLoading.style.display = "none";
    }

    private showError() {
      this.hideLoading();
      const contributionError = document.getElementById("contribution-error");
      const eventsError = document.getElementById("events-error");

      if (contributionError) contributionError.classList.remove("hidden");
      if (eventsError) eventsError.classList.remove("hidden");
    }

    private showEventsError() {
      const eventsLoading = document.getElementById("events-loading");
      const eventsError = document.getElementById("events-error");

      if (eventsLoading) eventsLoading.style.display = "none";
      if (eventsError) eventsError.classList.remove("hidden");
    }
  }

  // Initialize with intersection observer for lazy loading
  function initGitHubActivity() {
    const activitySection = document.getElementById("contribution-chart");
    if (!activitySection) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const username =
              document
                .querySelector("[data-username]")
                ?.getAttribute("data-username") || "FabiSax12";
            new GitHubActivity(username);
            observer.disconnect();
          }
        });
      },
      { rootMargin: "100px" },
    );

    observer.observe(activitySection);
  }

  // Initialize on DOM ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGitHubActivity);
  } else {
    initGitHubActivity();
  }

  // Re-initialize on page changes (for Astro)
  document.addEventListener("astro:page-load", initGitHubActivity);
</script>

<style>
  /* Smooth transitions for activity cards */
  #recent-events > div {
    transition: all 0.2s ease;
  }

  #recent-events > div:hover {
    transform: translateX(4px);
  }

  /* Contribution chart hover effects */
  #contribution-chart .grid > div > div:hover {
    transform: scale(1.2);
    transition: transform 0.1s ease;
  }
</style>
