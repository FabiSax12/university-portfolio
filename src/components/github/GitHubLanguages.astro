---
import { Code, TrendingUp } from "lucide-astro";

interface Props {
  username: string;
}

const { username } = Astro.props;
---

<div
  class="bg-gradient-to-br from-violet-50 to-purple-50 dark:from-violet-900/20 dark:to-purple-900/20 rounded-2xl p-8 border border-violet-200 dark:border-violet-700 hover:shadow-lg transition-all duration-300 h-full"
>
  <div class="flex items-center gap-3 mb-6">
    <div class="p-2 bg-violet-100 dark:bg-violet-800/50 rounded-lg">
      <Code class="w-5 h-5 text-violet-600 dark:text-violet-400" />
    </div>
    <h3 class="text-lg font-bold text-zinc-900 dark:text-white">
      Lenguajes Favoritos
    </h3>
  </div>

  <!-- Languages List -->
  <div id="languages-container" class="space-y-4">
    <!-- Loading State -->
    <div id="languages-loading" class="text-center py-8">
      <div
        class="inline-flex items-center gap-2 text-zinc-600 dark:text-zinc-400"
      >
        <div
          class="w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"
        >
        </div>
        Analizando repositorios...
      </div>
    </div>

    <!-- Error State -->
    <div id="languages-error" class="hidden text-center py-8 text-red-500">
      <p class="text-sm">Error al cargar los lenguajes</p>
    </div>
  </div>

  <!-- Stats Footer -->
  <div
    id="languages-footer"
    class="hidden mt-6 pt-4 border-t border-violet-200 dark:border-violet-700"
  >
    <div
      class="flex items-center justify-between text-sm text-zinc-600 dark:text-zinc-400"
    >
      <span>Basado en repositorios públicos</span>
      <div class="flex items-center gap-1">
        <TrendingUp class="w-4 h-4" />
        <span id="total-repos-analyzed">0</span>
      </div>
    </div>
  </div>
</div>

<script>
  import { githubConfig } from "@/data/github-config";

  interface LanguageStats {
    [key: string]: number;
  }

  interface LanguageConfig {
    color: string;
    icon?: string;
  }

  class GitHubLanguages {
    private username: string;
    private cache: Map<string, any> = new Map();
    private readonly CACHE_DURATION = 10 * 60 * 1000; // 10 minutes

    private readonly languageColors: Record<string, LanguageConfig> = {
      JavaScript: { color: "#f1e05a" },
      TypeScript: { color: "#2b7489" },
      React: { color: "#61dafb" },
      Vue: { color: "#4FC08D" },
      Python: { color: "#3572A5" },
      Java: { color: "#b07219" },
      "C#": { color: "#239120" },
      "C++": { color: "#f34b7d" },
      C: { color: "#555555" },
      PHP: { color: "#4F5D95" },
      Ruby: { color: "#701516" },
      Go: { color: "#00ADD8" },
      Rust: { color: "#dea584" },
      Swift: { color: "#ffac45" },
      Kotlin: { color: "#F18E33" },
      Dart: { color: "#00B4AB" },
      HTML: { color: "#e34c26" },
      CSS: { color: "#1572B6" },
      SCSS: { color: "#c6538c" },
      Shell: { color: "#89e051" },
      PowerShell: { color: "#012456" },
      Dockerfile: { color: "#384d54" },
      YAML: { color: "#cb171e" },
      JSON: { color: "#292929" },
      Markdown: { color: "#083fa1" },
    };

    constructor(username: string) {
      this.username = username;
      this.init();
    }

    async init() {
      try {
        await this.loadLanguages();
        this.hideLoading();
        this.showFooter();
      } catch (error) {
        console.error("Error loading GitHub languages:", error);
        this.showError();
      }
    }

    private async fetchWithCache(url: string): Promise<any> {
      const cacheKey = url;
      const cached = this.cache.get(cacheKey);

      if (cached && Date.now() - cached.timestamp < this.CACHE_DURATION) {
        return cached.data;
      }

      try {
        const response = await fetch(url);
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const data = await response.json();
        this.cache.set(cacheKey, { data, timestamp: Date.now() });
        return data;
      } catch (error) {
        if (cached) {
          return cached.data;
        }
        throw error;
      }
    }

    async loadLanguages() {
      // Get user's repositories
      const repos = await this.fetchWithCache(`/api/github?endpoint=repos`);

      const languageStats: LanguageStats = {};
      let totalBytes = 0;
      let reposAnalyzed = 0;

      // Analyze each repository's languages
      for (const repo of repos.data.slice(0, 30)) {
        // Limit to avoid rate limiting
        if (repo.fork) continue; // Skip forks

        try {
          const { data: languages } = await this.fetchWithCache(
            `/api/github?endpoint=repo-languages&repo=${repo.name}`,
          );

          if (Object.keys(languages).length > 0) {
            reposAnalyzed++;

            for (const [language, bytes] of Object.entries(languages)) {
              languageStats[language] =
                (languageStats[language] || 0) + (bytes as number);
              totalBytes += bytes as number;
            }
          }
        } catch (error) {
          console.warn(`Could not fetch languages for ${repo.name}:`, error);
          // Continue with other repos
        }
      }

      this.renderLanguages(languageStats, totalBytes, reposAnalyzed);
    }

    private renderLanguages(
      languageStats: LanguageStats,
      totalBytes: number,
      reposAnalyzed: number,
    ) {
      const container = document.getElementById("languages-container");
      if (!container) return;

      // Sort languages by usage
      const sortedLanguages = Object.entries(languageStats)
        .sort(([, a], [, b]) => b - a)
        .slice(0, githubConfig.ui.maxLanguages);

      container.innerHTML = "";

      sortedLanguages.forEach(([language, bytes], index) => {
        const percentage = (bytes / totalBytes) * 100;
        const config = this.languageColors[language] || { color: "#858585" };

        const languageElement = document.createElement("div");
        languageElement.className = "group";

        languageElement.innerHTML = `
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <div
                class="w-3 h-3 rounded-full"
                style="background-color: ${config.color}"
              ></div>
              <span class="text-sm font-medium text-zinc-900 dark:text-white">
                ${language}
              </span>
            </div>
            <span class="text-sm text-zinc-600 dark:text-zinc-400">
              ${percentage.toFixed(1)}%
            </span>
          </div>
          <div class="w-full bg-zinc-200 dark:bg-zinc-700 rounded-full h-2 overflow-hidden">
            <div
              class="h-full rounded-full transition-all duration-1000 ease-out"
              style="width: 0%; background-color: ${config.color}"
              data-width="${percentage}"
            ></div>
          </div>
        `;

        container.appendChild(languageElement);

        // Animate the progress bar
        setTimeout(() => {
          const progressBar = languageElement.querySelector(
            "[data-width]",
          ) as HTMLElement;
          if (progressBar) {
            progressBar.style.width = `${percentage}%`;
          }
        }, index * 100);
      });

      // Update footer
      const totalReposEl = document.getElementById("total-repos-analyzed");
      if (totalReposEl) {
        totalReposEl.textContent = reposAnalyzed.toString();
      }
    }

    private hideLoading() {
      const loadingEl = document.getElementById("languages-loading");
      if (loadingEl) {
        loadingEl.style.display = "none";
      }
    }

    private showError() {
      const loadingEl = document.getElementById("languages-loading");
      const errorEl = document.getElementById("languages-error");

      if (loadingEl) loadingEl.style.display = "none";
      if (errorEl) {
        errorEl.classList.remove("hidden");
      }
    }

    private showFooter() {
      const footerEl = document.getElementById("languages-footer");
      if (footerEl) {
        footerEl.classList.remove("hidden");
      }
    }
  }

  // Initialize with intersection observer for lazy loading
  function initGitHubLanguages() {
    const languagesSection = document.getElementById("languages-container");
    if (!languagesSection) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const username =
              document
                .querySelector("[data-username]")
                ?.getAttribute("data-username") || "FabiSax12";
            new GitHubLanguages(username);
            observer.disconnect();
          }
        });
      },
      { rootMargin: "50px" },
    );

    observer.observe(languagesSection);
  }

  // Initialize on DOM ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGitHubLanguages);
  } else {
    initGitHubLanguages();
  }
  // Re-initialize on page changes (for Astro)
  document.addEventListener("astro:page-load", initGitHubLanguages);
</script>
