---
import { Sun, Moon } from "lucide-astro";
import LanguageSwitcher from "@/features/i18n/ui/LanguageSwitcher.astro";

interface Props {
  currentLanguage: string;
}

const { currentLanguage } = Astro.props;
---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-zinc-900/80 backdrop-blur-sm border-b border-zinc-200 dark:border-zinc-800"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a class="flex items-center" href={Astro.currentLocale === 'en' ? '/en/' : '/'}>
        <span class="text-xl font-bold text-zinc-900 dark:text-white">
          Fabian
          <span class="text-violet-600 dark:text-violet-400">Vargas</span>
        </span>
      </a>
      <div class="flex items-center gap-2">
        <LanguageSwitcher currentLanguage={currentLanguage} />
        <button
          id="theme-toggle"
          type="button"
          class="p-2 rounded-lg bg-white dark:bg-zinc-800 text-zinc-600 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-700 transition-colors border border-zinc-200 dark:border-zinc-700"
          aria-label="Cambiar tema"
        >
          <Sun class="w-5 h-5 text-amber-500 hidden dark:block" />
          <Moon class="w-5 h-5 text-violet-600 block dark:hidden" />
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  const themeButton = document.getElementById("theme-toggle");

  themeButton?.addEventListener("click", () => {
    document.documentElement.classList.toggle("dark");

    // Save the theme preference in localStorage
    const currentTheme = document.documentElement.classList.contains("dark")
      ? "dark"
      : "light";

    localStorage.setItem("theme", currentTheme);
  });
</script>
