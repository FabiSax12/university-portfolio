---
import { Mail, Download } from "lucide-astro";
import Button from "../ui/Button.astro";
import Link from "../ui/Link.astro";
import { getTranslation } from "@/features/i18n/domain/getTranslation";
import type { Language } from "@/features/i18n/config/languages";

interface Props {
  cvUrl?: string;
  contactText?: string;
  downloadText?: string;
  fileName?: string;
}

const language = (Astro.currentLocale || 'es') as Language;
const t = getTranslation(language);

const {
  cvUrl = `/docs/${language}/CV - Fabian Vargas.pdf`,
  contactText = t.hero.CONTACT_BUTTON,
  downloadText = t.hero.DOWNLOAD_CV_BUTTON,
  fileName = "Fabian Vargas CV.pdf",
} = Astro.props;
---

<div class="flex flex-wrap justify-center lg:justify-start gap-4 pt-2">
  <!-- Contact Button -->
  <Button isDialogTrigger dialogId="contact">
    <Mail class="w-4 h-4 mr-2" />
    {contactText}
  </Button>

  <!-- Download CV Button -->
  <Link href={cvUrl} download={fileName}>
    <Download class="w-4 h-4 mr-2" />
    {downloadText}
  </Link>
</div>
