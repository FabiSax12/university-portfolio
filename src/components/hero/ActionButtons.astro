---
import { Mail, Download } from "lucide-astro";
import Button from "../ui/Button.astro";
import Link from "../ui/Link.astro";
import { getTranslation } from "@/features/i18n/domain/getTranslation";
import type { Language } from "@/features/i18n/config/languages";

interface Props {
  lang: Language;
  cvUrl?: string;
  contactText?: string;
  downloadText?: string;
  fileName?: string;
}

const { lang, ...otherProps } = Astro.props;
const t = getTranslation(lang);

const {
  cvUrl = `/docs/${lang}/CV - Fabian Vargas.pdf`,
  contactText = t.hero.CONTACT_BUTTON,
  downloadText = t.hero.DOWNLOAD_CV_BUTTON,
  fileName = "Fabian Vargas CV.pdf",
} = otherProps;
---

<script>
  import { track } from "@vercel/analytics";

  document.querySelectorAll<HTMLAnchorElement>("[data-analytics-event]").forEach((el) => {
    el.addEventListener("click", () => {
      const event = el.dataset.analyticsEvent!;
      const lang = el.dataset.analyticsLang;
      track(event, lang ? { lang } : {});
    });
  });
</script>

<div class="flex flex-wrap justify-center lg:justify-start gap-4 pt-2">
  <!-- Contact Button -->
  <Button isDialogTrigger dialogId="contact" analyticsEvent="contact_open">
    <Mail class="w-4 h-4 mr-2" />
    {contactText}
  </Button>

  <!-- Download CV Button -->
  <Link href={cvUrl} data-analytics-event="cv_download" data-analytics-lang={lang}>
    <!-- download={fileName}> -->
    <Download class="w-4 h-4 mr-2" />
    {downloadText}
  </Link>
</div>
