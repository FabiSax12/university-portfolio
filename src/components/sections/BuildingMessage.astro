---
import { Construction } from "lucide-astro";
import type { Language } from "@/features/i18n";
import { getTranslation } from "@/features/i18n/domain/getTranslation";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslation(lang);
---

<div class="opacity-0 py-16 animate-fade-in-up">
  <div
    class="bg-linear-to-r from-violet-50 to-zinc-50 dark:from-violet-950/30 dark:to-zinc-900 rounded-2xl overflow-hidden shadow-lg border border-violet-100 dark:border-violet-900/30 p-8"
  >
    <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
      <div class="flex-1 space-y-4 text-center lg:text-left">
        <h3
          class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-white"
        >
          {lang === 'es' ? 'Más secciones en construcción 🚧' : 'More sections under construction 🚧'}
        </h3><p
          class="text-zinc-600 dark:text-zinc-300 text-sm sm:text-base max-w-xl"
        >
          {lang === 'es' 
            ? 'Estoy trabajando para terminar esta sección.' 
            : 'I am working to finish this section.'}
          <br />
          {lang === 'es' 
            ? 'Regresa pronto y estará disponible para que la veas.' 
            : 'Come back soon and it will be available for you.'}
          <br />
          {lang === 'es' ? '¡Gracias por tu paciencia!' : 'Thank you for your patience!'}
        </p>
      </div>
    </div>
  </div>
</div>

