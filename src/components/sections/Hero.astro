---
import ProfileImage from "../hero/ProfileImage.astro";
import ActionButtons from "../hero/ActionButtons.astro";
import SocialLinks from "../hero/SocialLinks.astro";
import { getTranslation } from "@/features/i18n/domain/getTranslation";
import type { Language } from "@/features/i18n/config/languages";

interface Props {
  lang: Language;
  name?: string;
  title?: string;
  description?: string;
  profileImage?: string;
  cvUrl?: string;
}

const { lang, ...otherProps } = Astro.props;
const t = getTranslation(lang);

const {
  name = t.hero.NAME,
  title = t.hero.TITLE,
  description = t.hero.DESCRIPTION,
  profileImage = "/Yo.jpg",
  cvUrl = `/docs/${lang}/CV - Fabian Vargas.pdf`,
} = otherProps;
---

<div class="min-h-dvh flex flex-col pt-16 sm:pt-8">
  <div
    class="flex-1 flex flex-col-reverse lg:flex-row items-center justify-center gap-8 lg:gap-12 py-8 lg:py-20"
  >
    <!-- Content Section -->
    <div
      class="opacity-0 flex-1 space-y-4 lg:space-y-6 max-w-2xl px-4 text-center lg:text-left animate-fade-in-up"
    >
      <div class="space-y-2">
        <h1
          class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold text-zinc-900 dark:text-white leading-tight flex flex-wrap items-baseline gap-x-2 gap-y-1 justify-center lg:justify-start"
        >
          <span class="whitespace-nowrap">{t.hero.GREETING}</span>
          <span class="whitespace-nowrap text-violet-600 dark:text-violet-400"
            >{name}</span
          >
        </h1>

        <h2
          class="text-base sm:text-lg lg:text-xl xl:text-2xl text-zinc-600 dark:text-zinc-300 leading-relaxed"
        >
          {title}
        </h2>
      </div>

      <p
        class="text-sm sm:text-base lg:text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed max-w-xl mx-auto lg:mx-0"
      >
        {description}
      </p>

      <ActionButtons lang={lang} cvUrl={cvUrl} />
      <SocialLinks />
    </div>

    <!-- Profile Image -->
    <ProfileImage src={profileImage} alt={t.common.ARIA_PROFILE_IMAGE as string} />
  </div>
</div>
